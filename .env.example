# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# URL pública da sua aplicação (usado para gerar QR Codes)
# Em produção Railway: https://perfecaire-viewer-xxx.up.railway.app
BASE_URL=http://localhost:3000

# ── Auth JWT ───────────────────────────────────────────────────────────────────
# Troque por uma string longa e aleatória em produção!
JWT_SECRET=mude-isso-em-producao-use-openssl-rand-hex-32

# Senha do admin inicial (só usada na primeira inicialização do DB)
ADMIN_PASSWORD=sua-senha-aqui

# ── Banco de dados ─────────────────────────────────────────────────────────────
# Caminho local (Railway tem disco efêmero — use volume persistente ou Postgres)
DB_PATH=./data/perfecaire.db

# ── Cloudflare R2 ──────────────────────────────────────────────────────────────
# Painel Cloudflare → R2 → API Tokens → Create Token
R2_ENDPOINT=https://SEU_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=sua-access-key
R2_SECRET_ACCESS_KEY=sua-secret-key
R2_BUCKET_NAME=perfecaire-models

# (Opcional) Se o bucket for público, coloque a URL aqui para evitar URLs assinadas
# R2_PUBLIC_URL=https://models.perfecaire.com.br
