{
  "name": "perfecaire-viewer",
  "version": "1.0.0",
  "description": "Visualizador 3D PerfecAire — IFC, GLTF, OBJ, FBX",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build:client": "esbuild client/src/viewer.js --bundle --outfile=client/public/viewer.bundle.js --platform=browser --format=iife --loader:.wasm=file --public-path=/",
    "build": "npm run build:client",
    "postinstall": "npm run build"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "qrcode": "^1.5.3",
    "@aws-sdk/client-s3": "^3.540.0",
    "@aws-sdk/s3-request-presigner": "^3.540.0"
  },
  "devDependencies": {
    "esbuild": "^0.20.2",
    "nodemon": "^3.1.0"
  }
}
